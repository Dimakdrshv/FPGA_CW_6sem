#########################################################################################

build/

# Vivado project files
*.xpr
*.jou
*.log
*.rpt
*.str
*.xml
*.html
*.pb
*.dmp

# Vivado generated folders
.Xil/
*.cache/
*.hw/
*.ip_user_files/
*.sim/
*.runs/
*.gen/
*.srcs/

# Vivado generated files
*.os
*.prj
*.wcfg
*.wdb
*.vcd
*.saif
*.tcf

# XSim
xsim.dir/
xvlog.*
xelab.*
xsim.*

# Bitstreams / generated outputs
*.bit
*.bin
*.mcs
*.svf
*.ltx

# Checkpoints / netlists
*.dcp
*.edf
*.edif
*.sdf
*.ngc
*.ngd
*.ncd

# Reports / timing
*.tim
*.mrp
*.map
*.par

# OS / editor
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.iml
*~

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.env